# Sword Agent OS / AITuberKit local env template.
# Placeholder-only. Copy to .env for local development or distribution rendering.
# Do not put provider credentials in NEXT_PUBLIC_* values.

# Next.js path and build mode.
BASE_PATH=
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_RESTRICTED_MODE=false
NEXT_PUBLIC_LIVE2D_ENABLED=false

# Sword standard Thought Core route.
NEXT_PUBLIC_SYSTEM_CELL_AI_SERVICE=thought-core
NEXT_PUBLIC_SELECT_AI_SERVICE=thought-core
NEXT_PUBLIC_PROJECTION_VISUAL_AI_SERVICE=thought-core
NEXT_PUBLIC_PROJECTION_VISUAL_CONTINUOUS_MIC=false
THOUGHT_CORE_BASE_URL=http://127.0.0.1:18787
NEXT_PUBLIC_THOUGHT_CORE_BASE_URL=http://127.0.0.1:18787
THOUGHT_CORE_SESSION_ID=aituber-kit
NEXT_PUBLIC_THOUGHT_CORE_SESSION_ID=aituber-kit
THOUGHT_CORE_LOCALE=ja-JP

# Avatar and Projection Visual display defaults.
NEXT_PUBLIC_MODEL_TYPE=vrm
NEXT_PUBLIC_SELECTED_VRM_PATH=/vrm/nikechan_v1.vrm
NEXT_PUBLIC_SELECT_LANGUAGE=ja
NEXT_PUBLIC_CHARACTER_NAME=Nikechan
NEXT_PUBLIC_SHOW_ASSISTANT_TEXT=true
NEXT_PUBLIC_SHOW_CHARACTER_NAME=false
NEXT_PUBLIC_SHOW_CONTROL_PANEL=false
NEXT_PUBLIC_SHOW_INTRODUCTION=false

# Local voice output defaults.
NEXT_PUBLIC_SELECT_VOICE=voicevox
VOICEVOX_SERVER_URL=http://127.0.0.1:50021
NEXT_PUBLIC_VOICEVOX_SPEAKER=46
NEXT_PUBLIC_VOICEVOX_SPEED=1.0
NEXT_PUBLIC_VOICEVOX_PITCH=0.0
NEXT_PUBLIC_VOICEVOX_INTONATION=1.0

# Optional server-side provider keys. Keep blank unless that provider is selected.
OPENAI_API_KEY=
OPENAI_TTS_KEY=
OPENAI_EMBEDDING_KEY=
AIVIS_CLOUD_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_TTS_KEY=
STYLEBERTVITS2_API_KEY=
